def agregar_cliente(id_actual):
    print('')
    print('--- NUEVO CLIENTE ---')
    nombre = input("Nombre (persona o empresa): ").strip().title()
    telefono = pedir_entero("Teléfono (solo números): ")
    direccion = input("Dirección: ").strip().title()
    piso_depto = input("Piso/Depto (Enter si no corresponde): ").strip()
    observaciones = input("Observaciones: ").strip()
    es_empresa = pedir_opcion("¿Es empresa/consorcio?", ["si", "no"]) == "si"

    cliente = {
        "id": id_actual,
        "nombre": nombre,
        "telefono": telefono,
        "direccion": direccion,
        "piso_depto": piso_depto,
        "observaciones": observaciones,
        "es_empresa": es_empresa,
    }
    clientes.append(cliente)
    print("Cliente agregado con ID", id_actual)
    return id_actual + 1


def listar_clientes():
    print('')
    print('--- LISTA DE CLIENTES ---')
    if not clientes:
        print("No hay clientes cargados.")
        return
    for c in clientes:
        tipo = "EMPRESA" if c["es_empresa"] else "particular"
        piso = c["piso_depto"] if c["piso_depto"] else "-"
        print("[", c["id"], "]", c["nombre"], "(", tipo, ") - Tel:",
              c["telefono"], "-", c["direccion"], "-", piso)


def editar_cliente():
    listar_clientes()
    id_buscado = pedir_id("\nID del cliente a editar: ")
    cliente = buscar_por_id(clientes, id_buscado)
    if cliente is None:
        print("No existe un cliente con ese ID.")
        return
    print("Dejá vacío (Enter) para mantener el valor actual.")
    nuevo_nombre = input("Nombre [" + cliente["nombre"] + "]: ").strip().title()
    if nuevo_nombre:
        cliente["nombre"] = nuevo_nombre
    if pedir_opcion("¿Cambiar teléfono?", ["si", "no"]) == "si":
        cliente["telefono"] = pedir_entero("Nuevo teléfono (solo números): ")
    nueva_dir = input("Dirección [" + cliente["direccion"] + "]: ").strip().title()
    if nueva_dir:
        cliente["direccion"] = nueva_dir
    nuevo_piso = input("Piso/Depto [" + cliente["piso_depto"] + "]: ").strip()
    if nuevo_piso:
        cliente["piso_depto"] = nuevo_piso
    print("Cliente actualizado.")


def eliminar_cliente():
    listar_clientes()
    id_buscado = pedir_id("\nID del cliente a eliminar: ")
    cliente = buscar_por_id(clientes, id_buscado)
    if cliente is None:
