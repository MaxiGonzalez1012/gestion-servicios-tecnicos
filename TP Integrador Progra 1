def reporte_por_estado(estado):
    filtrados = [t for t in trabajos if t["estado"] == estado]
    print('')
    print("--- TRABAJOS:", estado.upper(), "---")
    if not filtrados:
        print("No hay trabajos en este estado.")
        return
    for t in filtrados:
        mostrar_trabajo(t)


def reporte_cobros_pendientes():
    pendientes = [t for t in trabajos if t["estado_pago"] == "Pendiente"]
    print('')
    print('--- COBROS PENDIENTES ---')
    if not pendientes:
        print("No hay cobros pendientes. ¡Todo cobrado!")
        return
    total = 0.0
    for t in pendientes:
        mostrar_trabajo(t)
        total += t["importe"]
    print('')
    print("TOTAL PENDIENTE DE COBRO: $", total)


def modulo_reportes():
    opcion = pedir_opcion("=== REPORTES Y CONSULTAS ===",
                          ["Trabajos pendientes",
                           "Trabajos realizados",
                           "Trabajos incompletos",
                           "Trabajos reprogramados",
                           "Cobros pendientes",
                           "Volver"])
    if opcion == "Trabajos pendientes":
        reporte_por_estado("Pendiente")
    elif opcion == "Trabajos realizados":
        reporte_por_estado("Realizado")
    elif opcion == "Trabajos incompletos":
        reporte_por_estado("Incompleto")
    elif opcion == "Trabajos reprogramados":
        reporte_por_estado("Reprogramado")
    elif opcion == "Cobros pendientes":
        reporte_cobros_pendientes()


# ============================================================
#  PROGRAMA PRINCIPAL (menú)
# ============================================================
def Programa_principal():
    print("=" * 50)
    print("  SISTEMA DE GESTIÓN - SERVICIOS TÉCNICOS")
    print("=" * 50)

    # Cargo los datos guardados de sesiones anteriores (si los hay).
    cargar_todo()

    # Contadores para generar IDs únicos. Arrancan despues del ultimo
    # ID que ya exista en los archivos, asi no se repiten.
    id_cliente_actual = proximo_id(clientes)
    id_tecnico_actual = proximo_id(tecnicos)
    id_trabajo_actual = proximo_id(trabajos)

    while True:
        try:
            opcion = pedir_opcion("========= MENÚ PRINCIPAL =========",
                                  ["Clientes", "Trabajos", "Cobros",
                                   "Técnicos", "Reportes y Consultas", "Salir"])
            if opcion == "Clientes":
                id_cliente_actual = modulo_clientes(id_cliente_actual)
            elif opcion == "Trabajos":
                id_trabajo_actual = modulo_trabajos(id_trabajo_actual)
            elif opcion == "Cobros":
                modulo_cobros()
            elif opcion == "Técnicos":
                id_tecnico_actual = modulo_tecnicos(id_tecnico_actual)
            elif opcion == "Reportes y Consultas":
                modulo_reportes()
            elif opcion == "Salir":
                print("Cerrando el sistema. ¡Hasta luego!")
                break
        
        except Exception as error:
            print("Ocurrió un error inesperado:", error)
            print("El sistema sigue funcionando.")


Programa_principal()
