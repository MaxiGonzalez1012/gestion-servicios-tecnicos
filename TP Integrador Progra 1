            print("Cancelado.")
            return
    clientes.remove(cliente)
    print("Cliente eliminado.")


def modulo_clientes(id_actual):
    opcion = pedir_opcion("=== CLIENTES ===",
                          ["Agregar", "Listar", "Editar", "Eliminar", "Volver"])
    if opcion == "Agregar":
        id_actual = agregar_cliente(id_actual)
