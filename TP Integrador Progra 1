def agregar_trabajo(id_actual):
    print('')
    print('--- NUEVO TRABAJO ---')
    if not clientes:
        print("Primero cargá al menos un cliente.")
        return id_actual
    if not tecnicos:
        print("Primero cargá al menos un técnico.")
        return id_actual

    listar_clientes()
    id_cli = pedir_id("ID del cliente: ")
    if buscar_por_id(clientes, id_cli) is None:
        print("Ese cliente no existe.")
        return id_actual

    listar_tecnicos()
    id_tec = pedir_id("ID del técnico asignado: ")
    if buscar_por_id(tecnicos, id_tec) is None:
        print("Ese técnico no existe.")
        return id_actual

    tipo = pedir_opcion("Tipo de servicio:",
                        ["aire", "eléctrico", "soporte"])
    descripcion = input("Descripción del problema: ").strip()
    fecha = input("Fecha (dd/mm/aaaa): ").strip()
    horario = input("Horario: ").strip()

    trabajo = {
        "id": id_actual,
        "id_cliente": id_cli,
        "id_tecnico": id_tec,
        "tipo_servicio": tipo,
        "descripcion": descripcion,
        "fecha": fecha,
        "horario": horario,
        "estado": "Pendiente",
        # --- campos de cobro (Módulo 3) ---
        "importe": 0.0,
        "estado_pago": "Pendiente",
        "medio_pago": "",
    }
    trabajos.append(trabajo)
    print("Trabajo agregado con ID", id_actual)
    return id_actual + 1


def mostrar_trabajo(t):
    cliente = buscar_por_id(clientes, t["id_cliente"])
    tecnico = buscar_por_id(tecnicos, t["id_tecnico"])
    nombre_cli = cliente["nombre"] if cliente else "(cliente borrado)"
    nombre_tec = tecnico["nombre"] if tecnico else "(técnico borrado)"
    print("[", t["id"], "]", t["tipo_servicio"].upper(), "-", nombre_cli,
          "| Técnico:", nombre_tec, "|", t["fecha"], t["horario"])
    print("     Problema:", t["descripcion"])
    print("     Estado:", t["estado"], "| Pago:", t["estado_pago"],
          "( $", t["importe"], ")", t["medio_pago"])


def listar_trabajos():
    print('')
    print('--- LISTA DE TRABAJOS ---')
    if not trabajos:
        print("No hay trabajos cargados.")
        return
    for t in trabajos:
        mostrar_trabajo(t)


def editar_trabajo():
    listar_trabajos()
    id_buscado = pedir_id("\nID del trabajo a editar: ")
    trabajo = buscar_por_id(trabajos, id_buscado)
    if trabajo is None:
        print("No existe un trabajo con ese ID.")
        return
    if pedir_opcion("¿Cambiar estado del trabajo?", ["si", "no"]) == "si":
        trabajo["estado"] = pedir_opcion("Nuevo estado:", estados)
    if pedir_opcion("¿Reasignar técnico?", ["si", "no"]) == "si":
        listar_tecnicos()
        id_tec = pedir_id("ID del nuevo técnico: ")
        if buscar_por_id(tecnicos, id_tec):
            trabajo["id_tecnico"] = id_tec
        else:
            print("Técnico inexistente, no se cambió.")
    nueva_fecha = input("Fecha [" + trabajo["fecha"] + "] (Enter mantiene): ").strip()
    if nueva_fecha:
        trabajo["fecha"] = nueva_fecha
    print("Trabajo actualizado.")


def eliminar_trabajo():
    listar_trabajos()
    id_buscado = pedir_id("\nID del trabajo a eliminar: ")
    trabajo = buscar_por_id(trabajos, id_buscado)
    if trabajo is None:
        print("No existe un trabajo con ese ID.")
        return
    trabajos.remove(trabajo)
    print("Trabajo eliminado.")


def modulo_trabajos(id_actual):
    opcion = pedir_opcion("=== TRABAJOS ===",
                          ["Agregar", "Listar", "Editar estado/datos",
                           "Eliminar", "Volver"])
    if opcion == "Agregar":
        id_actual = agregar_trabajo(id_actual)
        guardar_todo()
    elif opcion == "Listar":
        listar_trabajos()
    elif opcion == "Editar estado/datos":
        editar_trabajo()
        guardar_todo()
    elif opcion == "Eliminar":
        eliminar_trabajo()
        guardar_todo()
    return id_actual


